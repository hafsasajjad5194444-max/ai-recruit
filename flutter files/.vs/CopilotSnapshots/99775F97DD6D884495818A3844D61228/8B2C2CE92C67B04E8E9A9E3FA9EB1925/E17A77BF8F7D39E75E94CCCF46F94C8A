    <!-- Best Resume Popup Script -->
    <script>
        window.addEventListener('load', function() {
            // Best Resume Popup
            setTimeout(function() {
                const popup = document.getElementById('bestResumePopup');
                popup.classList.add('show');
                
                setTimeout(function() {
                    popup.classList.remove('show');
                }, 3000);
            }, 1000);
            
            // Floating Images Rotation
            const floatingImages = document.querySelectorAll('.floating-image');
            let currentImageIndex = 0;
            
            function rotateImages() {
                floatingImages[currentImageIndex].classList.remove('active');
                currentImageIndex = (currentImageIndex + 1) % floatingImages.length;
                floatingImages[currentImageIndex].classList.add('active');
            }
            
            // Start rotation after 5 seconds
            setInterval(rotateImages, 5000);
        });
    </script>
